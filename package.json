{
  "name": "webwin32-core",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "imports": {
    "#backends/*": {
      "types": "./src/backends/*",
      "default": "./dist/src/backends/*"
    },
    "#runtime/*": {
      "types": "./src/runtime/*",
      "default": "./dist/src/runtime/*"
    },
    "#x86/*": {
      "types": "./src/x86/*",
      "default": "./dist/src/x86/*"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:interpreter-wasm": "node dist/src/backends/wasm/interpreter/write-artifact.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run clean && tsc -p tsconfig.json && npm run build:interpreter-wasm && node --test 'dist/src/**/tests/*.test.js'"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
